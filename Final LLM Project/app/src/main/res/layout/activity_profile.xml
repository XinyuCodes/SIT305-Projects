<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4FF"
    android:padding="24dp">

    <TextView
        android:id="@+id/helloText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hello,"
        android:textSize="32sp"
        android:textColor="#6B7280"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="32dp"/>

    <TextView
        android:id="@+id/nameText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Username"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#1E3A8A"
        app:layout_constraintTop_toTopOf="@id/helloText"
        app:layout_constraintStart_toEndOf="@id/helloText"
        android:layout_marginStart="8dp"/>

    <androidx.cardview.widget.CardView
        android:id="@+id/scoreCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardCornerRadius="20dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="#1E3A8A"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/helloText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/descriptionText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your Last Quiz Result"
                android:textSize="14sp"
                android:textColor="#93C5FD"
                android:letterSpacing="0.08"
                android:layout_marginBottom="16dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/totalquestionsnumber"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="52sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>

                    <TextView
                        android:id="@+id/TotalQuestionsText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Questions"
                        android:textSize="12sp"
                        android:textColor="#93C5FD"/>

                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="80dp"
                    android:background="#3B5FBB"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/correctAnswersLastQuiz"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="52sp"
                        android:textStyle="bold"
                        android:textColor="#60D394"/>

                    <TextView
                        android:id="@+id/totalanswerstext"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Correct Answers"
                        android:textSize="12sp"
                        android:textColor="#93C5FD"/>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <Button
        android:id="@+id/viewQuizHistory"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:text="See My Last Quiz"
        android:backgroundTint="#1E3A8A"
        android:textColor="#FFFFFF"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/scoreCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/StartNewQuizButton"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginTop="220dp"
        android:backgroundTint="#8BC34A"
        android:text="Start A New Quiz"
        android:textColor="#FFFFFF"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/scoreCard" />

    <Button
        android:id="@+id/shareButton2"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:text="Share My Profile"
        android:backgroundTint="#2563EB"
        android:textColor="#FFFFFF"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/viewQuizHistory"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/upgradePlan"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:text="Upgrade Plan"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:textColor="#1E3A8A"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/shareButton2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>